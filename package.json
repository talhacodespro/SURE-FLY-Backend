{
  "name": "ts-express-kit",
  "version": "1.1.4",
  "description": "A TypeScript starter kit for building Express applications with best practices.",
  "main": "index.js",
  "bin": {
    "ts-express-kit": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "lint": "eslint src --ext .ts",
    "lint:fix": "npx eslint src --fix",
    "prettier": "prettier --ignore-path .gitignore --write \"./src/**/*.+(js|ts|json)\"",
    "prettier:fix": "npx prettier --write src",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register ./src/server.ts",
    "prod": "node -r tsconfig-paths/register ./dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "typescript",
    "express",
    "node",
    "ts-express-kit"
  ],
  "author": "Nasim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nazmulhasannasim333/ts-express-kit.git"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "prisma": "^7.2.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
